<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prontuário Clínico</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>

    <main class="content">
      <section class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h3 class="mb-1">Prontuário: <%= animal.nome %></h3>
          <small class="text-secondary"><%= animal.especie %> • <%= animal.raca %> • Tutor: <%= animal.tutor %></small>
        </div>
        <button type="button" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Nova consulta</button>
      </section>

      <section class="row g-3 mb-3">
        <div class="col-md-3"><div class="metric-card"><small>Peso atual</small><div class="metric-value"><%= animal.pesoAtual %> kg</div></div></div>
        <div class="col-md-3"><div class="metric-card"><small>Último retorno</small><div class="metric-value"><%= animal.ultimoRetorno %></div></div></div>
        <div class="col-md-3"><div class="metric-card"><small>Alergias</small><div class="metric-value"><%= alergias.length %></div></div></div>
        <div class="col-md-3"><div class="metric-card"><small>Exames pendentes</small><div class="metric-value"><%= exames.filter((e) => e.status !== 'Concluído').length %></div></div></div>
      </section>

      <section class="row g-3">
        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-clock-history me-2"></i>Histórico clínico (linha do tempo)</h5>
            <ul class="timeline" id="timeline-list">
              <% historico.forEach((item) => { %>
                <li class="timeline-item"><span class="timeline-date"><%= item.data %></span><p class="mb-0"><%= item.evento %></p></li>
              <% }) %>
            </ul>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-clipboard2-pulse me-2"></i>Anamnese estruturada</h5>
            <form data-append-target="#timeline-list" class="row g-2">
              <div class="col-6"><input class="form-control" data-label="Sintomas" name="sintomas" placeholder="Sintomas" /></div>
              <div class="col-6"><input class="form-control" data-label="Hábitos" name="habitos" placeholder="Hábitos" /></div>
              <div class="col-12"><input class="form-control" data-label="Alimentação" name="alimentacao" placeholder="Alimentação" /></div>
              <div class="col-12"><button type="submit" class="btn btn-primary w-100">Salvar anamnese</button></div>
            </form>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-thermometer-half me-2"></i>Exames solicitados</h5>
            <ul class="list-group">
              <% exames.forEach((exame) => { %>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                  <span><strong><%= exame.tipo %></strong> • <%= exame.data %></span>
                  <span class="tag <%= exame.status === 'Concluído' ? 'success' : 'warning' %>"><%= exame.status %></span>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-file-earmark-arrow-up me-2"></i>Upload de laudos e imagens</h5>
            <input class="form-control mb-2" type="file" multiple />
            <small class="text-secondary d-block mb-3">Suporte para PDFs, imagens de raio-x e ultrassom.</small>
            <div class="d-flex gap-2 flex-wrap">
              <span class="tag success">laudo_hemograma.pdf</span>
              <span class="tag">rx_torax_03-02.png</span>
            </div>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-activity me-2"></i>Evolução por consulta</h5>
            <textarea class="form-control mb-2" rows="4" placeholder="Descreva evolução clínica do paciente..."></textarea>
            <button type="button" class="btn btn-outline-primary w-100">Registrar evolução</button>
          </div>
        </div>

        <div class="col-lg-6">
          <div class="panel">
            <h5><i class="bi bi-prescription2 me-2"></i>Prescrição digital</h5>
            <form class="row g-2">
              <div class="col-md-6"><input class="form-control" placeholder="Medicamento" /></div>
              <div class="col-md-6"><input class="form-control" placeholder="Dose" /></div>
              <div class="col-md-6"><input class="form-control" placeholder="Frequência" /></div>
              <div class="col-md-6"><input class="form-control" placeholder="Duração" /></div>
              <div class="col-12"><button type="button" class="btn btn-primary w-100">Emitir prescrição</button></div>
            </form>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="panel">
            <h5><i class="bi bi-bell me-2"></i>Alertas de retorno</h5>
            <p class="mb-1">Próximo retorno: <strong><%= alertas.proximoRetorno %></strong></p>
            <span class="tag warning">Vacina em 12 dias</span>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="panel">
            <h5><i class="bi bi-exclamation-diamond me-2"></i>Alergias e restrições</h5>
            <% alergias.forEach((item) => { %>
              <span class="tag danger"><%= item %></span>
            <% }) %>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="panel">
            <h5><i class="bi bi-graph-up-arrow me-2"></i>Peso e crescimento</h5>
            <ul class="mb-0">
              <% crescimento.forEach((item) => { %>
                <li><%= item.periodo %>: <strong><%= item.peso %> kg</strong></li>
              <% }) %>
            </ul>
          </div>
        </div>

        <div class="col-12">
          <div class="panel">
            <h5><i class="bi bi-journal-bookmark me-2"></i>Protocolos padrão de tratamento</h5>
            <div class="d-flex flex-wrap gap-2">
              <% protocolos.forEach((protocolo) => { %>
                <button type="button" class="btn btn-outline-primary"><%= protocolo %></button>
              <% }) %>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
