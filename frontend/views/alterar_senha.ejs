<!DOCTYPE html>
<html lang="pt">
<head><title>Alterar Senha</title><link rel="stylesheet" href="/css/bootstrap.min.css"></head>
<body><div class="container mt-5"><h2>Alterar Senha</h2>
<% if (error) { %><p class="alert alert-danger"><%= error %></p><% } %>
<form action="/auth/alterar-senha" method="POST">
<input type="password" name="senhaAtual" placeholder="Senha atual" class="form-control" required>
<input type="password" name="senhaNova" placeholder="Nova senha" class="form-control" required>
<button type="submit" class="btn btn-primary">Alterar</button></form></div></body></html>