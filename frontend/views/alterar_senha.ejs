<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Alterar Senha | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
        <h2 class="mb-4">Alterar senha</h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger mb-4"><%= error %></div>
        <% } %>
        <div class="card" style="max-width: 480px;">
          <div class="card-body">
            <form action="/auth/alterar-senha" method="POST">
              <div class="mb-3">
                <label for="senhaAtual" class="form-label">Senha atual</label>
                <input type="password" name="senhaAtual" id="senhaAtual" class="form-control" placeholder="Digite sua senha atual" required>
              </div>
              <div class="mb-4">
                <label for="senhaNova" class="form-label">Nova senha</label>
                <input type="password" name="senhaNova" id="senhaNova" class="form-control" placeholder="Digite a nova senha" required>
              </div>
              <button type="submit" class="btn btn-primary">Alterar senha</button>
              <a href="/auth/perfil" class="btn btn-outline-secondary ms-2">Cancelar</a>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
