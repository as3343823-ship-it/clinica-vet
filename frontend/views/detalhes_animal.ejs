<!DOCTYPE html>
<html lang="pt">
<head><title>Cadastro Animal</title><link rel="stylesheet" href="/css/bootstrap.min.css"></head>
<body><div class="container"><h2>Cadastrar Animal</h2>
<form action="/animais/cadastrar-animal" method="POST" enctype="multipart/form-data">
<input type="text" name="nome" placeholder="Nome do animal" required>
<input type="number" name="idade" placeholder="Idade" required>
<select name="especie"><% especies.forEach(esp => { %><option value="<%= esp %>"><%= esp %></option><% }); %></select>
<input type="text" name="sexo" placeholder="Sexo (Macho/Fêmea)" required>
<input type="number" name="peso" placeholder="Peso (kg)" required>
<textarea name="sintomas" placeholder="Sintomas"></textarea>
<select name="gravidade"><option value="1">Leve</option><option value="2">Moderado</option><option value="3">Grave</option></select>
<input type="file" name="imagem" accept="image/*">
<button type="submit">Cadastrar</button></form>
<script src="/js/app.js"></script></div></body></html>