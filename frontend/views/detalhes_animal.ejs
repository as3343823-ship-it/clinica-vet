<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ficha do Animal | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
    <a href="/animais/lista-completa" class="btn btn-outline-secondary mb-4">&larr; Voltar</a>
    <a href="/animais/prontuario-clinico/<%= animal.id %>" class="btn btn-outline-primary mb-4 ms-2">Ver prontuário clínico</a>
    <div class="card">
      <div class="card-body">
        <h3 class="mb-3">Ficha: <%= animal.nome %></h3>
        <div class="row">
          <div class="col-md-4">
            <% if (animal.imagem_path) { %>
              <img src="<%= animal.imagem_path %>" alt="Foto do animal" class="img-fluid rounded" />
            <% } else { %>
              <div class="border rounded p-4 text-center text-muted">Sem foto</div>
            <% } %>
          </div>
          <div class="col-md-8">
            <p><strong>ID:</strong> <%= animal.id %></p>
            <p><strong>Especie:</strong> <%= animal.especie %></p>
            <p><strong>Sexo:</strong> <%= animal.sexo %></p>
            <p><strong>Peso:</strong> <%= animal.peso %> kg</p>
            <p><strong>Classificação de Manchester:</strong> <%= animal.classif %></p>
            <p><strong>Pontuario:</strong> <%= animal.pontuario %></p>
            <p><strong>Sintomas:</strong> <%= animal.sintomas %></p>
            <hr>
            <h5>Tutor associado</h5>
            <p><strong>Nome:</strong> <%= animal.tutor_nome %></p>
            <p><strong>Email:</strong> <%= animal.tutor_email %></p>
            <p><strong>Telefone:</strong> <%= animal.tutor_telefone || 'N/D' %></p>
          </div>
        </div>
      </div>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>