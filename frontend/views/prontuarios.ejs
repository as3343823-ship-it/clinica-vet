<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prontuários | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
          <h2 class="mb-0">Prontuários dos animais</h2>
          <a class="btn btn-outline-secondary" href="<%= (typeof user !== 'undefined' && user && user.tipo === 'funcionario') ? '/menu-funcionario' : '/menu-cliente' %>">Voltar</a>
        </div>
        <p class="text-muted mb-4">Lista organizada por prioridade (maior pontuação primeiro).</p>
        <% const lista = Array.isArray(pontuarios) ? pontuarios : []; %>
        <% if (!lista.length) { %>
          <div class="alert alert-info">Nenhum prontuário disponível.</div>
        <% } else { %>
          <div class="card">
            <div class="card-body">
              <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Animal</th>
                      <th>Classificação</th>
                      <th>Pontuação</th>
                      <% if (typeof user !== 'undefined' && user && user.tipo === 'funcionario') { %>
                        <th>Tutor ID</th>
                        <th>Ações</th>
                      <% } %>
                    </tr>
                  </thead>
                  <tbody>
                    <% lista.forEach(item => { %>
                      <tr>
                        <td><%= item.id %></td>
                        <td><%= item.nome %></td>
                        <td><span class="badge bg-primary"><%= item.classif %></span></td>
                        <td><span class="badge bg-warning text-dark"><%= item.pontuario %></span></td>
                        <% if (typeof user !== 'undefined' && user && user.tipo === 'funcionario') { %>
                          <td><%= item.tutor_id %></td>
                          <td>
                            <a class="btn btn-sm btn-outline-primary" href="/animais/prontuario-clinico/<%= item.id %>">Ver prontuário</a>
                          </td>
                        <% } %>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
