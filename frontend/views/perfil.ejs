<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Perfil | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <% const safeUser = (typeof user !== 'undefined' && user) ? user : {}; %>
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
        <h2 class="mb-4">Perfil de <%= safeUser.username || safeUser.email || safeUser.nome || 'Utilizador' %></h2>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger mb-4"><%= error %></div>
        <% } %>
        <div class="card">
          <div class="card-body">
            <% if (safeUser.tipo === 'funcionario') { %>
              <p class="mb-2"><strong>Username:</strong> <%= safeUser.username %></p>
              <p class="text-muted mb-4">Alterações de perfil de funcionário são feitas pelo administrador.</p>
              <a href="/menu-funcionario" class="btn btn-outline-secondary">Voltar</a>
            <% } else { %>
            <form action="/auth/editar-perfil" method="POST">
              <div class="mb-4">
                <label for="nome" class="form-label">Nome</label>
                <input id="nome" type="text" name="nome" value="<%= safeUser.nome || '' %>" class="form-control" required>
              </div>
              <button type="submit" class="btn btn-primary">Salvar alterações</button>
              <a href="/menu-cliente" class="btn btn-outline-secondary ms-2">Voltar</a>
            </form>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
