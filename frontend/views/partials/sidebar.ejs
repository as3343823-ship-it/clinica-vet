<% const u = typeof user !== 'undefined' ? user : {}; %>
<% const isTutor = u.tipo === 'tutor'; %>
<% const isFuncionario = u.tipo === 'funcionario'; %>
<% const isAdmin = isFuncionario && u.nivel === 'administrador'; %>
<div class="sidebar">
  <h4 class="brand"><i class="bi bi-heart-pulse-fill"></i> Vet Pata-Node</h4>
  <ul class="nav flex-column">
    <% if (isTutor) { %>
      <li class="nav-item"><a class="nav-link" href="/animais/listar-animais"><i class="bi bi-heart-pulse me-2"></i> Meus animais</a></li>
      <li class="nav-item"><a class="nav-link" href="/animais/cadastrar-animal"><i class="bi bi-plus-circle me-2"></i> Cadastrar animal</a></li>
      <li class="nav-item"><a class="nav-link" href="/agenda/ver-agenda"><i class="bi bi-calendar-check me-2"></i> Agenda</a></li>
      <li class="nav-item"><a class="nav-link" href="/animais/pontuarios"><i class="bi bi-speedometer2 me-2"></i> Prontuários</a></li>
    <% } else if (isFuncionario) { %>
      <li class="nav-item"><a class="nav-link" href="/animais/lista-completa"><i class="bi bi-list-ul me-2"></i> Todos os animais</a></li>
      <li class="nav-item"><a class="nav-link" href="/animais/cadastrar-animal"><i class="bi bi-plus-circle me-2"></i> Cadastrar animal</a></li>
      <li class="nav-item"><a class="nav-link" href="/agenda/ver-agenda"><i class="bi bi-calendar-event me-2"></i> Agenda</a></li>
      <li class="nav-item"><a class="nav-link" href="/relatorios/gerar-relatorios"><i class="bi bi-bar-chart me-2"></i> Relatórios</a></li>
      <li class="nav-item"><a class="nav-link" href="/animais/pontuarios"><i class="bi bi-speedometer2 me-2"></i> Prontuários</a></li>
      <% if (isAdmin) { %>
        <li class="nav-item"><a class="nav-link" href="/admin/listar-usuarios"><i class="bi bi-person-gear me-2"></i> Usuários</a></li>
      <% } %>
    <% } %>
    <li class="nav-item"><a class="nav-link" href="/auth/perfil"><i class="bi bi-person me-2"></i> Perfil</a></li>
    <li class="nav-item"><a class="nav-link" href="/auth/alterar-senha"><i class="bi bi-key me-2"></i> Alterar senha</a></li>
    <li class="nav-item"><a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
  </ul>
  <hr>
  <div class="toggle-btn d-flex align-items-center" id="mode-toggle"><i class="bi bi-moon-stars-fill me-2"></i> Modo Escuro</div>
</div>
