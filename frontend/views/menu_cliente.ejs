<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Área do Cliente | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <% const lista = Array.isArray(animais) ? animais : []; %>
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
        <h2 class="mb-3">Olá, <%= (typeof user !== 'undefined' && user) ? (user.email || user.username || 'Cliente') : 'Cliente' %></h2>
        <p class="lead">Aqui voce e gerencia apenas os seus animais.</p>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Meus animais</h5>
                <% if (!lista.length) { %>
                    <p class="mb-0">Ainda ainda não tem animais cadastrados para sua conta.</p>
                <% } else { %>
                    <div class="row g-3">
                        <% lista.forEach(animal => { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100">
                                    <% if (animal.imagem_path) { %>
                                        <img src="<%= animal.imagem_path %>" class="card-img-top" alt="Foto de <%= animal.nome %>" style="height:180px;object-fit:cover;">
                                    <% } %>
                                    <div class="card-body">
                                        <h6 class="card-title mb-1"><%= animal.nome %></h6>
                                        <p class="mb-1"><strong>Espécie:</strong> <%= animal.especie %></p>
                                        <p class="mb-1"><strong>Classificação:</strong> <%= animal.classif %></p>
                                        <p class="mb-1"><strong>Pontuação:</strong> <%= animal.pontuario %></p>
                                        <p class="mb-2"><strong>Status:</strong> Em acompanhamento</p>
                                        <a class="btn btn-sm btn-outline-primary" href="/animais/prontuario-clinico/<%= animal.id %>">Ver prontuário</a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>