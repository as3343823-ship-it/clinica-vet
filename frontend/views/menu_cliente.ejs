<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Área do Cliente</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
    <% const safeUser = (typeof user !== 'undefined' && user) ? user : {}; %>
    <% const lista = Array.isArray(animais) ? animais : []; %>
    <% const baseName = safeUser.nome || safeUser.username || safeUser.email || 'Cliente'; %>
    <% const firstToken = String(baseName).trim().split(' ')[0]; %>
    <% const firstName = firstToken.includes('@') ? firstToken.split('@')[0] : firstToken; %>
    <div class="sidebar">
        <h4 class="text-primary fw-bold">Vet Pata-Node</h4>
        <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link" href="/animais/listar-animais"><i class="bi bi-heart-pulse me-2"></i> Meus animais</a></li>
            <li class="nav-item"><a class="nav-link" href="/animais/cadastrar-animal"><i class="bi bi-plus-circle me-2"></i> Cadastrar novo animal</a></li>
            <li class="nav-item"><a class="nav-link" href="/agenda/ver-agenda"><i class="bi bi-calendar-check me-2"></i> Agenda e status</a></li>
            <li class="nav-item"><a class="nav-link" href="/animais/pontuarios"><i class="bi bi-file-medical me-2"></i> Meus prontuários</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
        </ul>
        <hr>
        <div class="toggle-btn d-flex align-items-center" id="mode-toggle"><i class="bi bi-moon-stars-fill me-2"></i> Modo Escuro</div>
    </div>

    <main class="content">
        <h2 class="mb-3">Olá, <%= firstName %></h2>
        <p class="lead">Aqui você vê e gerencia apenas os seus animais.</p>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Meus animais</h5>
                <% if (!lista.length) { %>
                    <p class="mb-0">Ainda não há animais cadastrados para sua conta.</p>
                <% } else { %>
                    <div class="row g-3">
                        <% lista.forEach(animal => { %>
                            <div class="col-md-6 col-lg-4">
                                <div class="card h-100">
                                    <% if (animal.imagem_path) { %>
                                        <img src="<%= animal.imagem_path %>" class="card-img-top" alt="Foto de <%= animal.nome %>" style="height:180px;object-fit:cover;">
                                    <% } %>
                                    <div class="card-body">
                                        <h6 class="card-title mb-1"><%= animal.nome %></h6>
                                        <p class="mb-1"><strong>Espécie:</strong> <%= animal.especie %></p>
                                        <p class="mb-1"><strong>Classificação:</strong> <%= animal.classif %></p>
                                        <p class="mb-1"><strong>Pontuário:</strong> <%= animal.pontuario %></p>
                                        <p class="mb-0"><strong>Status:</strong> Em acompanhamento</p>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>
