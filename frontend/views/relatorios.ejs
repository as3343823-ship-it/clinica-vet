<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relatórios | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <h2 class="mb-0">Relatórios</h2>
          <a class="btn btn-outline-secondary" href="/menu-funcionario">Voltar</a>
        </div>
        <% if (typeof total !== 'undefined' && total !== null) { %>
          <div class="card mb-4">
            <div class="card-body">
              <h5 class="card-title mb-3">Resumo geral</h5>
              <p class="mb-0 fs-5">Total de animais cadastrados: <strong><%= total %></strong></p>
            </div>
          </div>
        <% } %>
        <% if (typeof classifCount !== 'undefined' && classifCount !== null && classifCount.length) { %>
          <div class="card mb-4">
            <div class="card-body">
              <h5 class="card-title mb-4">Distribuição por classificação (Manchester)</h5>
              <table class="table table-striped">
                <thead><tr><th>Classificação</th><th>Quantidade</th></tr></thead>
                <tbody>
                  <% classifCount.forEach(c => { %>
                    <tr><td><span class="badge bg-primary"><%= c.classif %></span></td><td><%= c.count %></td></tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>
        <% if (typeof animais !== 'undefined' && animais !== null && animais.length) { %>
          <div class="card">
            <div class="card-body">
              <h5 class="card-title mb-4">Sistema Manchester - Animais por prioridade</h5>
              <table class="table table-striped">
                <thead><tr><th>Animal</th><th>Classificação</th></tr></thead>
                <tbody>
                  <% animais.forEach(a => { %>
                    <tr><td><%= a.nome %></td><td><span class="badge bg-primary"><%= a.classif %></span></td></tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>