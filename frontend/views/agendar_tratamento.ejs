<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Agendar Tratamento</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
</head>
<body>
    <% const listaAnimais = Array.isArray(animais) ? animais : []; %>
    <div class="container mt-5" style="max-width: 860px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Agendar Tratamento</h2>
            <a class="btn btn-outline-secondary" href="/agenda/ver-agenda">Ver Agenda</a>
        </div>

        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/agenda/agendar-tratamento" method="POST">
            <div class="mb-3">
                <label for="animalId" class="form-label">Animal</label>
                <select name="animalId" id="animalId" class="form-select" required>
                    <option value="">Selecione...</option>
                    <% listaAnimais.forEach(a => { %>
                        <option value="<%= a.id %>"><%= a.nome %> — Tutor: <%= a.tutor_nome %></option>
                    <% }) %>
                </select>
            </div>

            <div class="mb-3">
                <label for="tipo" class="form-label">Tipo de Tratamento</label>
                <input type="text" name="tipo" id="tipo" class="form-control" required>
            </div>

            <div class="mb-3">
                <label for="descricao" class="form-label">Descrição</label>
                <textarea name="descricao" id="descricao" class="form-control" rows="3" required></textarea>
            </div>

            <div class="mb-4">
                <label for="data" class="form-label">Data</label>
                <input type="date" name="data" id="data" class="form-control" required>
            </div>

            <button type="submit" class="btn btn-primary w-100">Agendar Tratamento</button>
        </form>
    </div>
</body>
</html>
