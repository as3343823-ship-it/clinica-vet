<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agendar Tratamento | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
      <div class="content-page">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
          <h2 class="mb-0">Agendar tratamento</h2>
          <a class="btn btn-outline-secondary" href="/agenda/ver-agenda">Ver agenda</a>
        </div>
        <% const listaAnimais = Array.isArray(animais) ? animais : []; %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger mb-4"><%= error %></div>
        <% } %>
        <div class="card" style="max-width: 640px;">
          <div class="card-body">
            <form action="/agenda/agendar-tratamento" method="POST">
              <div class="mb-4">
                <label for="animalId" class="form-label">Animal</label>
                <select name="animalId" id="animalId" class="form-select" required>
                  <option value="">Selecione o animal...</option>
                  <% listaAnimais.forEach(a => { %>
                    <option value="<%= a.id %>"><%= a.nome %> — Tutor: <%= a.tutor_nome %></option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-4">
                <label for="tipo" class="form-label">Tipo de tratamento</label>
                <input type="text" name="tipo" id="tipo" class="form-control" placeholder="Ex: Consulta, Vacinação..." required>
              </div>
              <div class="mb-4">
                <label for="descricao" class="form-label">Descrição</label>
                <textarea name="descricao" id="descricao" class="form-control" rows="3" placeholder="Descreva o tratamento..." required></textarea>
              </div>
              <div class="mb-4">
                <label for="data" class="form-label">Data</label>
                <input type="date" name="data" id="data" class="form-control" required>
              </div>
              <button type="submit" class="btn btn-primary">Agendar tratamento</button>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
