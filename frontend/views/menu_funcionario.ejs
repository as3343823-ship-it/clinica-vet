<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Menu Funcionário | Vet Pata-Node</title>
  <link rel="stylesheet" href="/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
  <% const lista = Array.isArray(animais) ? animais : []; %>
  <div class="app-shell">
    <%- include('partials/sidebar') %>
    <main class="content">
        <h2 class="mb-2">Bem-vindo, <%= user.username %></h2>
        <p class="text-muted mb-4">Gestão completa de animais e tutores.</p>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Lista completa de animais</h5>
                <% if (!lista.length) { %>
                    <p class="mb-0">Ainda não existem animais cadastrados.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th><th>Nome</th><th>Classif.</th><th>Pontuarios</th><th>Tutor</th><th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% lista.forEach(animal => { %>
                                    <tr>
                                        <td><%= animal.id %></td>
                                        <td><%= animal.nome %></td>
                                        <td><span class="badge text-bg-primary"><%= animal.classif %></span></td>
                                        <td><span class="badge text-bg-warning text-dark"><%= animal.pontuario %></span></td>
                                        <td><%= animal.tutor_nome %> (<%= animal.tutor_email %>)</td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-primary" href="/animais/<%= animal.id %>">Ficha</a>
                                            <a class="btn btn-sm btn-outline-info ms-1" href="/animais/prontuario-clinico/<%= animal.id %>">Prontuário</a>
                                            <form action="/animais/dar-alta" method="POST" class="d-inline ms-1">
                                                <input type="hidden" name="animalId" value="<%= animal.id %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Dar alta</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>