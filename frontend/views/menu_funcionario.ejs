<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu Funcionário</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
    <div class="sidebar">
        <h4 class="text-primary fw-bold">Vet Pata-Node</h4>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link active" href="/animais/cadastrar-animal">
                    <i class="bi bi-plus-circle me-2"></i> Cadastrar Animal
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/agenda/agendar-tratamento">
                    <i class="bi bi-calendar-event me-2"></i> Agendar Tratamento
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/relatorios/gerar-relatorios">
                    <i class="bi bi-bar-chart me-2"></i> Relatórios
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/admin/criar-funcionario">
                    <i class="bi bi-person-plus me-2"></i> Criar Funcionário
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/auth/logout">
                    <i class="bi bi-box-arrow-right me-2"></i> Sair
                </a>
            </li>
        </ul>
        <hr>
        <div class="toggle-btn d-flex align-items-center" id="mode-toggle">
            <i class="bi bi-moon-stars-fill me-2"></i> Modo Escuro
        </div>
    </div>

    <div class="content">
        <h2 class="mb-4">Bem-vindo, <%= user.username %></h2>
        <!-- Conteúdo da página aqui -->
    </div>

    <script src="/js/app.js"></script>
</body>
</html>