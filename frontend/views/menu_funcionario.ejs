<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu Funcionário</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body data-bs-theme="light">
    <% const lista = Array.isArray(animais) ? animais : []; %>
    <div class="sidebar">
        <h4 class="text-primary fw-bold">Vet Pata-Node</h4>
        <ul class="nav flex-column">
            <li class="nav-item"><a class="nav-link" href="/animais/lista-completa"><i class="bi bi-list-ul me-2"></i> Todos os animais</a></li>
            <li class="nav-item"><a class="nav-link" href="/animais/cadastrar-animal"><i class="bi bi-plus-circle me-2"></i> Cadastrar Animal</a></li>
            <li class="nav-item"><a class="nav-link" href="/agenda/ver-agenda"><i class="bi bi-calendar-event me-2"></i> Agenda</a></li>
            <li class="nav-item"><a class="nav-link" href="/relatorios/gerar-relatorios"><i class="bi bi-bar-chart me-2"></i> Relatórios</a></li>
            <li class="nav-item"><a class="nav-link" href="/animais/pontuarios"><i class="bi bi-speedometer2 me-2"></i> Prontuários</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i> Sair</a></li>
        </ul>
        <hr>
        <div class="toggle-btn d-flex align-items-center" id="mode-toggle"><i class="bi bi-moon-stars-fill me-2"></i> Modo Escuro</div>
    </div>

    <main class="content">
        <h2 class="mb-2">Bem-vindo, <%= user.username %></h2>
        <p class="text-muted mb-4">Gestão completa de animais e tutores.</p>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Lista completa de animais</h5>
                <% if (!lista.length) { %>
                    <p class="mb-0">Ainda não existem animais cadastrados.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th><th>Nome</th><th>Classif.</th><th>Pontuário</th><th>Tutor</th><th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% lista.forEach(animal => { %>
                                    <tr>
                                        <td><%= animal.id %></td>
                                        <td><%= animal.nome %></td>
                                        <td><span class="badge text-bg-primary"><%= animal.classif %></span></td>
                                        <td><span class="badge text-bg-warning text-dark"><%= animal.pontuario %></span></td>
                                        <td><%= animal.tutor_nome %> (<%= animal.tutor_email %>)</td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-primary" href="/animais/<%= animal.id %>">Ficha</a>
                                            <form action="/animais/dar-alta" method="POST" class="d-inline">
                                                <input type="hidden" name="animalId" value="<%= animal.id %>">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Dar alta</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="/js/app.js"></script>
</body>
</html>
